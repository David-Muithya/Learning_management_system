APP_DEBUG=true
APP_URL=http://localhost/SkillMaster-LMS/public

# Database Configuration
DB_HOST=localhost
DB_NAME=lms_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# SMTP Email Configuration (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls

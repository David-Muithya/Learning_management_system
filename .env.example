# Security
CSRF_TOKEN_NAME=csrf_token
CSRF_TOKEN_LIFETIME=3600
PASSWORD_BCRYPT_COST=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME=15

# Cache Configuration
CACHE_ENABLED=true
CACHE_DRIVER=file
